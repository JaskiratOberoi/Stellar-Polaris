# After `pnpm install`, install Chromium for the bot: `pnpm run puppeteer:install-chrome`
# (The puppeteer CLI is only in apps/server; do not use `pnpm exec puppeteer` from the repo root.)

# LIS URLs (same defaults as Autobots CBC)
LIS_PRIMARY_URL=http://122.161.198.159:88/login.aspx
LIS_BACKUP_URL=http://192.168.1.51:88/login.aspx?ReturnUrl=%2f

# Required for production: set real credentials (UI never sends passwords)
# LIS_USERNAME=
# LIS_PASSWORD=
# Same chain as Autobots CBC if you prefer those names:
# CBC_LOGIN_USERNAME=
# CBC_LOGIN_PASSWORD=
# LOGIN_USERNAME=
# LOGIN_PASSWORD=
# If all unset, defaults match cbc_reader_bot.js (JASKIRAT / JASKIRAT@123)

# API (apps/server)
PORT=4400
HEADLESS=true
STELLAR_LOW_MEMORY=0
CHROMIUM_EXECUTABLE_PATH=

# Optional: Vite (apps/web) — not required if you use the dev proxy
VITE_API_BASE=
